@using CinemaManagement.Web.Models.MovieViewModels
@model HomeIndexViewModel
@{
    ViewData["Title"] = "Trang Chủ";
    var dangChieu = Model.DangChieu;
    var sapChieu  = Model.SapChieu;
}

<!-- ===== HERO ===== -->
<section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-grid-lines"></div>
    <div class="hero-content">
        <div class="hero-badge">
            <span>🎬</span> Đặt Vé Trực Tuyến — Chọn Ghế Thực Tế
        </div>
        <h1 class="hero-title">
            Trải Nghiệm Điện Ảnh<br>
            <span>Vượt Giới Hạn</span>
        </h1>
        <p class="hero-subtitle">
            NEON-FLORA Cinema — Nơi công nghệ gặp gỡ thiên nhiên. Không gian xem phim Cyberpunk độc đáo với sơ đồ ghế thực tế, đặt vé chỉ trong 60 giây.
        </p>
        <div class="hero-buttons">
            <a href="/Movie?trangThai=DangChieu" class="btn btn-primary btn-lg">
                🎥 Xem Phim Đang Chiếu
            </a>
            <a href="/Account/Register" class="btn btn-secondary btn-lg">
                🌿 Tham Gia Ngay
            </a>
        </div>

        <!-- Feature Cards -->
        <div style="display:grid; grid-template-columns: repeat(3,1fr); gap:16px; margin-top:48px; max-width:700px;">
            @foreach (var feature in new[] {
                ("🎫", "Đặt Vé Nhanh", "Chọn ghế thực tế, thanh toán trong vài giây"),
                ("🌟", "Phòng VIP", "Giường đôi sang trọng, dịch vụ tận nơi"),
                ("🍿", "FnB Cao Cấp", "Bắp rang bơ premium, đồ uống craft beer")
            })
            {
                <div style="padding:16px; background:rgba(13,21,32,0.7); border:1px solid rgba(0,245,255,0.12); border-radius:12px; backdrop-filter:blur(10px);">
                    <div style="font-size:1.8rem; margin-bottom:8px;">@feature.Item1</div>
                    <div style="font-weight:700; font-size:0.9rem; margin-bottom:4px;">@feature.Item2</div>
                    <div style="font-size:0.775rem; color:var(--text-muted);">@feature.Item3</div>
                </div>
            }
        </div>
    </div>
</section>

<div style="max-width:1280px; margin:0 auto; padding:0 24px;">

<!-- ===== ĐANG CHIẾU ===== -->
@if (dangChieu.Any())
{
    <section class="page-section">
        <div class="section-header">
            <h2 class="section-title">Đang Chiếu</h2>
            <a href="/Movie?trangThai=DangChieu" class="section-link">Xem tất cả →</a>
        </div>
        <div class="movies-grid">
            @foreach (var phim in dangChieu.Take(8))
            {
                <a href="/Movie/Details/@phim.PhimId" class="movie-card" id="movie-@phim.PhimId">
                    <div class="movie-poster">
                        @if (!string.IsNullOrEmpty(phim.PosterUrl))
                        {
                            <img src="@phim.PosterUrl" alt="@phim.TenPhim" loading="lazy" />
                        }
                        else
                        {
                            <div class="movie-poster-placeholder">🎬</div>
                        }
                        <span class="movie-badge badge-dang-chieu">Đang chiếu</span>
                        <span class="movie-badge badge-age">@phim.GioiHanDoTuoi</span>
                        <div class="movie-overlay">
                            <span class="btn-book">🎫 Đặt Vé Ngay</span>
                        </div>
                    </div>
                    <div class="movie-info">
                        <div class="movie-title">@phim.TenPhim</div>
                        <div class="movie-meta">
                            <span>@phim.ThoiLuongText</span>
                            @if (!string.IsNullOrEmpty(phim.NgonNgu))
                            {
                                <span class="movie-meta-dot">•</span>
                                <span>@phim.NgonNgu</span>
                            }
                        </div>
                    </div>
                </a>
            }
        </div>
    </section>
}

<!-- ===== SẮP CHIẾU ===== -->
@if (sapChieu.Any())
{
    <section class="page-section">
        <div class="section-header">
            <h2 class="section-title">Sắp Chiếu</h2>
            <a href="/Movie?trangThai=SapChieu" class="section-link">Xem tất cả →</a>
        </div>
        <div class="movies-grid">
            @foreach (var phim in sapChieu.Take(6))
            {
                <a href="/Movie/Details/@phim.PhimId" class="movie-card" id="movie-sap-@phim.PhimId">
                    <div class="movie-poster">
                        @if (!string.IsNullOrEmpty(phim.PosterUrl))
                        {
                            <img src="@phim.PosterUrl" alt="@phim.TenPhim" loading="lazy" />
                        }
                        else
                        {
                            <div class="movie-poster-placeholder">🎬</div>
                        }
                        <span class="movie-badge badge-sap-chieu">Sắp chiếu</span>
                        <span class="movie-badge badge-age">@phim.GioiHanDoTuoi</span>
                    </div>
                    <div class="movie-info">
                        <div class="movie-title">@phim.TenPhim</div>
                        <div class="movie-meta">
                            @if (phim.NgayKhoiChieu.HasValue)
                            {
                                <span>📅 @phim.NgayKhoiChieu.Value.ToString("dd/MM/yyyy")</span>
                            }
                            else
                            {
                                <span>@phim.ThoiLuongText</span>
                            }
                        </div>
                    </div>
                </a>
            }
        </div>
    </section>
}

<!-- ===== EMPTY STATE ===== -->
@if (!dangChieu.Any() && !sapChieu.Any())
{
    <div class="empty-state">
        <div class="empty-icon">🎬</div>
        <div class="empty-title">Chưa có phim nào</div>
        <div class="empty-text">Lịch chiếu phim sẽ được cập nhật sớm.</div>
    </div>
}

</div>
