@using CinemaManagement.Web.Models.TicketViewModels
@model BookingConfirmationViewModel
@{
    ViewData["Title"] = "Đặt Vé Thành Công";
    var hoaDonId = Model.HoaDonId;
}

<div class="container">
    <div class="confirmation-card">
        <div class="confirmation-icon">🎉</div>
        <h1 class="confirmation-title">Đặt Vé Thành Công!</h1>
        <p class="confirmation-id">Mã hóa đơn: <strong style="color:var(--neon-cyan);">#@hoaDonId.ToString("D6")</strong></p>

        <p style="color:var(--text-secondary); font-size:0.9rem; line-height:1.7; margin-bottom:32px;">
            Vé của bạn đã được xác nhận. Vui lòng giữ mã QR trên vé để soát vé tại cửa.<br>
            Chúng tôi đã gửi xác nhận qua email (nếu có đăng ký).
        </p>

        <!-- Steps -->
        <div style="display:flex; justify-content:center; gap:32px; margin-bottom:32px; flex-wrap:wrap;">
            @foreach (var (icon, step) in new[] { ("🎫", "Nhận vé tại My Tickets"), ("📱", "Mở QR code"), ("🚪", "Soát vé tại cửa") })
            {
                <div style="text-align:center; max-width:120px;">
                    <div style="font-size:2rem; margin-bottom:8px;">@icon</div>
                    <div style="font-size:0.8rem; color:var(--text-secondary);">@step</div>
                </div>
            }
        </div>

        <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
            <a href="/Ticket/History" class="btn btn-primary" id="btn-xem-ve">🎫 Xem Vé Của Tôi</a>
            <a href="/" class="btn btn-secondary" id="btn-trang-chu">🏠 Trang Chủ</a>
        </div>
    </div>
</div>
