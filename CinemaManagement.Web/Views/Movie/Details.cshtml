@using CinemaManagement.Web.Models.MovieViewModels
@model MovieDetailsViewModel
@{
    var movie = Model.Movie;
    ViewData["Title"] = movie.TenPhim;
    var lichChieus = Model.Showtimes;
    var ngayChieu  = Model.SelectedDate;
    var ngayCoLich = Model.AvailableDates;
}

<div class="container" style="padding-top:48px; padding-bottom:60px;">

    <!-- Movie Detail Header -->
    <div style="display:grid; grid-template-columns:280px 1fr; gap:48px; align-items:start; margin-bottom:60px;">
        <!-- Poster -->
        <div style="position:sticky; top:88px;">
            <div style="border-radius:16px; overflow:hidden; border:1px solid var(--border-subtle); box-shadow:var(--shadow-neon-cyan);">
                @if (!string.IsNullOrEmpty(movie.PosterUrl))
                {
                    <img src="@movie.PosterUrl" alt="@movie.TenPhim" style="width:100%; display:block;" />
                }
                else
                {
                    <div style="padding-top:150%; background:var(--bg-dark); display:flex; align-items:center; justify-content:center; font-size:5rem; position:relative;">
                        <span style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center;">🎬</span>
                    </div>
                }
            </div>
            @if (movie.DangChieu)
            {
                <a href="#showtimes" class="btn btn-primary btn-block" style="margin-top:16px;" id="btn-chon-suat">
                    🎫 Chọn Suất Chiếu
                </a>
            }
        </div>

        <!-- Info -->
        <div>
            <!-- Badges -->
            <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px;">
                @if (movie.DangChieu)
                {
                    <span style="padding:4px 12px; background:rgba(48,209,88,0.15); border:1px solid rgba(48,209,88,0.4); border-radius:100px; font-size:0.75rem; font-weight:700; color:var(--neon-green);">● Đang Chiếu</span>
                }
                else if (movie.SapChieu)
                {
                    <span style="padding:4px 12px; background:rgba(255,214,10,0.15); border:1px solid rgba(255,214,10,0.4); border-radius:100px; font-size:0.75rem; font-weight:700; color:var(--neon-yellow);">● Sắp Chiếu</span>
                }
                <span style="padding:4px 12px; background:rgba(255,45,120,0.1); border:1px solid rgba(255,45,120,0.3); border-radius:100px; font-size:0.75rem; font-weight:700; color:var(--neon-pink);">@movie.GioiHanDoTuoi</span>
                @foreach (var tl in movie.TheLoais.Take(3))
                {
                    <span style="padding:4px 12px; background:var(--border-subtle); border:1px solid var(--border-subtle); border-radius:100px; font-size:0.75rem; color:var(--text-secondary);">@tl</span>
                }
            </div>

            <h1 style="font-size:clamp(1.6rem, 3vw, 2.5rem); font-weight:900; line-height:1.1; margin-bottom:8px;">@movie.TenPhim</h1>
            @if (!string.IsNullOrEmpty(movie.TenGoc))
            {
                <p style="font-size:1rem; color:var(--text-muted); margin-bottom:16px; font-style:italic;">@movie.TenGoc</p>
            }

            <!-- Metadata Grid -->
            <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(160px,1fr)); gap:12px; margin-bottom:28px;">
                @foreach (var item in new[] {
                    ("⏱️", "Thời lượng", movie.ThoiLuongText),
                    ("🌐", "Ngôn ngữ",   movie.NgonNgu ?? "—"),
                    ("🏭", "Sản xuất",   movie.NuocSanXuat ?? "—"),
                    ("📅", "Khởi chiếu", movie.NgayKhoiChieu?.ToString("dd/MM/yyyy") ?? "—")
                })
                {
                    <div style="padding:12px; background:var(--bg-card); border:1px solid var(--border-subtle); border-radius:10px;">
                        <div style="font-size:1.2rem; margin-bottom:4px;">@item.Item1</div>
                        <div style="font-size:0.7rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:1px; margin-bottom:2px;">@item.Item2</div>
                        <div style="font-size:0.875rem; font-weight:600;">@item.Item3</div>
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(movie.DaoDien))
            {
                <p style="margin-bottom:8px;"><span style="color:var(--text-muted); font-size:0.875rem;">Đạo diễn: </span><strong>@movie.DaoDien</strong></p>
            }
            @if (!string.IsNullOrEmpty(movie.DienVienChinh))
            {
                <p style="margin-bottom:16px;"><span style="color:var(--text-muted); font-size:0.875rem;">Diễn viên: </span><span>@movie.DienVienChinh</span></p>
            }

            @if (!string.IsNullOrEmpty(movie.MoTa))
            {
                <div style="margin-bottom:24px;">
                    <h3 style="font-size:1rem; font-weight:700; color:var(--text-secondary); text-transform:uppercase; letter-spacing:1px; margin-bottom:10px;">Nội Dung</h3>
                    <p style="color:var(--text-secondary); line-height:1.8; font-size:0.9rem;">@movie.MoTa</p>
                </div>
            }

            @if (!string.IsNullOrEmpty(movie.TrailerUrl))
            {
                <a href="@movie.TrailerUrl" target="_blank" rel="noopener" class="btn btn-secondary" id="btn-trailer">
                    ▶ Xem Trailer
                </a>
            }
        </div>
    </div>

    <!-- ===== LỊCH CHIẾU ===== -->
    @if (movie.DangChieu || lichChieus.Any())
    {
        <div id="showtimes">
            <div class="section-header">
                <h2 class="section-title">Lịch Chiếu</h2>
            </div>

            <!-- Date Tabs -->
            <div class="date-tabs">
                @foreach (var ngay in ngayCoLich)
                {
                    var isActive = ngay.Date == ngayChieu.Date;
                    var dayName  = ngay.Date == DateTime.Today ? "Hôm nay" : ngay.ToString("ddd", new System.Globalization.CultureInfo("vi-VN"));
                    <a href="/Movie/Details/@movie.PhimId?ngay=@ngay.ToString("yyyy-MM-dd")"
                       class="date-tab @(isActive ? "active" : "")"
                       id="date-tab-@ngay.ToString("yyyyMMdd")">
                        <span class="date-tab-day">@dayName</span>
                        <span class="date-tab-num">@ngay.Day</span>
                        <span class="date-tab-month">@ngay.ToString("MMM")</span>
                    </a>
                }
            </div>

            <!-- Showtime Pills -->
            @if (lichChieus.Any())
            {
                <div class="showtime-pills">
                    @foreach (var lc in lichChieus)
                    {
                        <a href="/Ticket/Booking/@lc.LichChieuId" class="showtime-pill" id="showtime-@lc.LichChieuId">
                            <span class="pill-time">@lc.GioBatDauText</span>
                            <span class="pill-room">@lc.TenPhong · @lc.LoaiPhong</span>
                            @if (lc.ConGhe)
                            {
                                <span class="pill-seats">@lc.SoGheTrong ghế trống</span>
                            }
                            else
                            {
                                <span style="font-size:0.7rem; color:var(--neon-pink);">Hết ghế</span>
                            }
                        </a>
                    }
                </div>
            }
            else
            {
                <div style="padding:40px; text-align:center; color:var(--text-muted);">
                    <p>Không có suất chiếu nào vào ngày @ngayChieu.ToString("dd/MM/yyyy").</p>
                    <p style="font-size:0.875rem; margin-top:8px;">Vui lòng chọn ngày khác.</p>
                </div>
            }
        </div>
    }

</div>
