@using CinemaManagement.Web.Models.MovieViewModels
@model MovieCatalogViewModel
@{
    ViewData["Title"] = "Danh Sách Phim";

    var searchTerm = Model.SearchTerm;

    var trangThai = Model.TrangThai;

    var titleText = trangThai switch
    {

        "DangChieu" => "Đang Chiếu",

        "SapChieu" => "Sắp Chiếu",

        _ => "Tất Cả Phim"

    };
}

<div class="container page-section">
    <!-- Header -->
    <div class="section-header">
        <h1 class="section-title">@titleText</h1>
        <span style="color:var(--text-muted); font-size:0.875rem;">@Model.Movies.Count phim</span>
    </div>

    <!-- Filter Bar -->
    <form method="get" action="/Movie" style="display:flex; gap:12px; flex-wrap:wrap; margin-bottom:32px;">
        <input type="text" name="q" value="@searchTerm" placeholder="Tìm tên phim..." class="form-control"
            style="max-width:280px;" id="search-input" />
        <select name="trangThai" class="form-control" style="max-width:180px;" id="filter-status"
            onchange="this.form.submit()">
            <option value="" selected="@(string.IsNullOrEmpty(trangThai))">Tất cả</option>
            <option value="DangChieu" selected="@(trangThai == "DangChieu")">Đang chiếu</option>
            <option value="SapChieu" selected="@(trangThai == "SapChieu")">Sắp chiếu</option>
        </select>
        <button type="submit" class="btn btn-primary btn-sm" id="btn-search">🔍 Tìm kiếm</button>
        @if (!string.IsNullOrEmpty(searchTerm) || !string.IsNullOrEmpty(trangThai))

        {
            <a href="/Movie" class="btn btn-secondary btn-sm" id="btn-clear">✕ Xóa bộ lọc</a>
        }
    </form>

    <!-- Grid -->
    @if (Model.Movies.Any())

    {
        <div class="movies-grid">
            @foreach (var phim in Model.Movies)

            {
                <a href="/Movie/Details/@phim.PhimId" class="movie-card" id="movie-card-@phim.PhimId">
                    <div class="movie-poster">
                        @if (!string.IsNullOrEmpty(phim.PosterUrl))

                        {
                            <img src="@phim.PosterUrl" alt="@phim.TenPhim" loading="lazy" />
                        }

                        else

                        {
                            <div class="movie-poster-placeholder">🎬</div>
                        }
                        @if (phim.DangChieu)

                        {
                            <span class="movie-badge badge-dang-chieu">Đang chiếu</span>
                        }

                        else if (phim.SapChieu)

                        {
                            <span class="movie-badge badge-sap-chieu">Sắp chiếu</span>
                        }
                        <span class="movie-badge badge-age">@phim.GioiHanDoTuoi</span>
                        @if (phim.DangChieu)

                        {
                            <div class="movie-overlay">
                                <span class="btn-book">🎫 Đặt Vé Ngay</span>
                            </div>
                        }
                    </div>
                    <div class="movie-info">
                        <div class="movie-title">@phim.TenPhim</div>
                        <div class="movie-meta">
                            <span>@phim.ThoiLuongText</span>
                            @if (phim.SapChieu && phim.NgayKhoiChieu.HasValue)
                            {
                                <span class="movie-meta-dot">•</span>
                                <span>@phim.NgayKhoiChieu.Value.ToString("dd/MM")</span>
                            }
                        </div>
                    </div>
                </a>
            }
        </div>
    }

    else

    {
        <div class="empty-state">
            <div class="empty-icon">🔍</div>
            <div class="empty-title">Không tìm thấy phim nào</div>
            <div class="empty-text">Thử tìm với từ khóa khác hoặc xóa bộ lọc.</div>
            <a href="/Movie" class="btn btn-primary" id="btn-reset">Xem tất cả phim</a>
        </div>
    }
</div>
