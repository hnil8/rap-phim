@using CinemaManagement.Web.Models.AccountViewModels
@model RegisterViewModel
@{
    ViewData["Title"] = "Đăng Ký";
}

<div class="form-card">
    <div class="form-title">
        <span style="background:linear-gradient(135deg,var(--neon-cyan),var(--neon-pink));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;">
            Tham Gia NEON-FLORA
        </span>
    </div>
    <p class="form-subtitle">Đăng ký để đặt vé, tích điểm và nhận ưu đãi độc quyền</p>

    <form asp-action="Register" asp-controller="Account" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" style="color:var(--neon-pink);font-size:0.875rem;margin-bottom:16px;padding:12px;background:rgba(255,45,120,0.08);border-radius:8px;border:1px solid rgba(255,45,120,0.2);"></div>

        <div class="form-group">
            <label class="form-label" for="reg-hoten">👤 Họ và Tên *</label>
            <input asp-for="HoTen" id="reg-hoten" class="form-control" placeholder="Nguyễn Văn A" required />
            <span asp-validation-for="HoTen" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label class="form-label" for="reg-sdt">📱 Số Điện Thoại *</label>
            <input asp-for="SoDienThoai" id="reg-sdt" class="form-control" type="tel"
                   placeholder="0xxxxxxxxx" pattern="[0-9]{10,11}" maxlength="11" required />
            <span asp-validation-for="SoDienThoai" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label class="form-label" for="reg-email">✉️ Email</label>
            <input asp-for="Email" id="reg-email" class="form-control" type="email" placeholder="email@example.com" />
            <span asp-validation-for="Email" class="field-validation-error"></span>
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
            <div class="form-group">
                <label class="form-label" for="reg-gioitinh">Giới Tính</label>
                <select asp-for="GioiTinh" id="reg-gioitinh" class="form-control">
                    <option value="">— Chọn —</option>
                    <option value="Nam">Nam</option>
                    <option value="Nu">Nữ</option>
                    <option value="Khac">Khác</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label" for="reg-ngaysinh">Ngày Sinh</label>
                <input asp-for="NgaySinh" id="reg-ngaysinh" class="form-control" type="date" />
            </div>
        </div>

        <button type="submit" class="btn btn-primary btn-block" id="btn-register" style="margin-top:8px;">
            🌿 Tạo Tài Khoản
        </button>
    </form>

    <div class="form-divider">hoặc</div>

    <p style="text-align:center; font-size:0.875rem; color:var(--text-secondary);">
        Đã có tài khoản?
        <a href="/Account/Login" style="color:var(--neon-cyan); font-weight:600;">Đăng nhập</a>
    </p>
</div>

@section Scripts {
<script>
document.getElementById('btn-register')?.addEventListener('click', function() {
    setTimeout(() => { this.disabled = true; this.textContent = 'Đang tạo tài khoản...'; }, 100);
});
</script>
}
