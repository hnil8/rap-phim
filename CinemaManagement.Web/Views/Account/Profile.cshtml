@using CinemaManagement.Web.Models.AccountViewModels
@model ProfileViewModel
@{
    ViewData["Title"] = "Hồ Sơ Cá Nhân";
}

<div class="container page-section">
    <h1 class="section-title" style="margin-bottom:32px;">Hồ Sơ Cá Nhân</h1>

    <div class="profile-grid">
        <!-- Profile Sidebar Card -->
        <div class="profile-card">
            <div class="profile-avatar">
                @Model.AvatarText
            </div>
            <div class="profile-name">@Model.HoTen</div>
            <div class="profile-phone">@Model.SoDienThoai</div>

            @if (!string.IsNullOrEmpty(Model.TenHangThanhVien))
            {
                <div class="member-badge" style="border-color:@(Model.MauHang ?? "var(--neon-cyan)"); color:@(Model.MauHang ?? "var(--neon-cyan)"); background:@(Model.MauHang ?? "rgba(0,245,255,0.1)")20; margin:12px auto; display:inline-flex;">
                    ⭐ @Model.TenHangThanhVien
                </div>
            }

            <div class="points-display">
                <div class="points-number">@Model.DiemTichLuy.ToString("N0")</div>
                <div class="points-label">Điểm Tích Lũy</div>
            </div>

            <div style="margin-top:16px;">
                <p style="font-size:0.78rem; color:var(--text-muted);">Thành viên từ</p>
                <p style="font-size:0.875rem; font-weight:600;">@Model.NgayDangKy.ToString("dd/MM/yyyy")</p>
            </div>

            <a href="/Ticket/History" class="btn btn-secondary btn-block" style="margin-top:20px;" id="btn-lich-su">
                🎫 Lịch Sử Vé
            </a>
        </div>

        <!-- Edit Form -->
        <div>
            <div style="background:var(--bg-card); border:1px solid var(--border-subtle); border-radius:20px; padding:32px;">
                <h2 style="font-size:1.1rem; font-weight:700; margin-bottom:24px;">Chỉnh Sửa Thông Tin</h2>

                <form asp-action="Profile" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" style="color:var(--neon-pink);font-size:0.875rem;margin-bottom:16px;"></div>

                    <div class="form-group">
                        <label class="form-label">👤 Họ và Tên</label>
                        <input asp-for="HoTen" class="form-control" required id="edit-hoten" />
                        <span asp-validation-for="HoTen" class="field-validation-error"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">📱 Số Điện Thoại</label>
                        <input type="tel" value="@Model.SoDienThoai" class="form-control" disabled
                               style="opacity:0.6; cursor:not-allowed;" id="edit-sdt" />
                        <small style="color:var(--text-muted); font-size:0.775rem;">Số điện thoại không thể thay đổi</small>
                    </div>

                    <div class="form-group">
                        <label class="form-label">✉️ Email</label>
                        <input asp-for="Email" class="form-control" id="edit-email" placeholder="email@example.com" />
                        <span asp-validation-for="Email" class="field-validation-error"></span>
                    </div>

                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                        <div class="form-group">
                            <label class="form-label">Giới Tính</label>
                            <select asp-for="GioiTinh" class="form-control" id="edit-gioitinh">
                                <option value="">— Chọn —</option>
                                <option value="Nam" @(Model.GioiTinh == "Nam" ? "selected" : "")>Nam</option>
                                <option value="Nu"  @(Model.GioiTinh == "Nu"  ? "selected" : "")>Nữ</option>
                                <option value="Khac" @(Model.GioiTinh == "Khac" ? "selected" : "")>Khác</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Ngày Sinh</label>
                            <input asp-for="NgaySinh" type="date" class="form-control" id="edit-ngaysinh" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary" id="btn-save-profile">
                        💾 Lưu Thay Đổi
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
